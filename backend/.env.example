# ===== LLM 配置 =====
# OpenAI兼容API密钥（支持OpenAI、Azure OpenAI、Ollama等）
OPENAI_API_KEY=sk-your-api-key-here
# API基础地址（默认OpenAI，可改为本地Ollama: http://localhost:11434/v1）
OPENAI_API_BASE=https://api.openai.com/v1
# 使用的模型名称
LLM_MODEL=gpt-4o

# ===== MongoDB 配置 =====
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=thought_incubator

# ===== 服务器配置 =====
HOST=0.0.0.0
PORT=8000

# ===== 辩论配置 =====
# 最大轮次（防止无限循环）
MAX_ROUNDS=20
# 达成共识的评分阈值（1-10）
SCORE_THRESHOLD=6
# 上下文token压缩阈值
MAX_CONTEXT_TOKENS=6000
